# =============================================================================
# Bomboli API — Environment configuration template
# Copy to .env for local development. Never commit secrets.
# =============================================================================

# -------- App --------
NODE_ENV=
PORT=
APP_URL=
APP_NAME=
ALLOWED_ORIGINS=

# -------- Database (Supabase Postgres) --------
DATABASE_URL=
DIRECT_URL=

# -------- Supabase --------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_WEBHOOK_SECRET=

# -------- Redis --------
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# -------- JWT (backend-issued) --------
JWT_SECRET=
JWT_EXPIRATION=

# -------- Rate limiting --------
RATE_LIMIT_TTL=
RATE_LIMIT_MAX=

# -------- Idempotency --------
IDEMPOTENCY_TTL_HOURS=

# -------- Observability --------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=
METRICS_TOKEN=

# -------- Payments — Stripe --------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -------- Payments — PayPal --------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE=
PAYPAL_WEBHOOK_ID=

# -------- Payments — Pawapay (Mobile Money) --------
PAWAPAY_API_KEY=
PAWAPAY_API_BASE=
PAWAPAY_WEBHOOK_SECRET=
