generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  // Only Bomboli-owned extensions. Supabase-managed extensions
  // (pg_graphql, pg_net, supabase_vault, pgcrypto, uuid-ossp, pg_stat_statements)
  // live in dedicated schemas (extensions/vault/graphql) and are out of
  // Prisma's concern.
  extensions = [postgis, pg_trgm]
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
  DELIVERY_PARTNER
}

model User {
  id          String   @id @default(cuid())
  supabaseId  String   @unique
  email       String   @unique
  phone       String?  @unique
  role        UserRole @default(BUYER)
  displayName String?
  avatarUrl   String?

  // Client-side UX preferences mirrored on the server so they survive a
  // device wipe. 'fr' is the only fully supported language for v1.
  preferredLanguage String @default("fr")
  themePref         String @default("system") // 'system' | 'light' | 'dark'

  // Last-known GPS position (web/native geolocation). Used as the default
  // origin when a request omits an explicit lat/lng for proximity queries.
  defaultLocation Unsupported("geography(Point, 4326)")?

  // Mirrored from auth.users via the Supabase webhook. Null until the user
  // verifies via Supabase Auth.
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastSignInAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses     Address[]
  devices       Device[]
  sellerProfile SellerProfile?
  deliverer     Deliverer?
  cart          Cart?
  orders        Order[]        @relation("OrderBuyer")

  @@map("users")
}

model Address {
  id                   String   @id @default(cuid())
  userId               String
  label                String // 'home' | 'work' | 'other' | free-form
  formatted            String
  location             Unsupported("geography(Point, 4326)")
  gateCode             String?
  floor                String?
  deliveryInstructions String?
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Device {
  id         String   @id @default(cuid())
  userId     String
  platform   String // 'ios' | 'android' | 'web'
  pushToken  String   @unique
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

// ---------------------------------------------------------------------------
// M2 — Sellers, verifications, stats, listings
// ---------------------------------------------------------------------------

enum VerificationKind {
  IDENTITY
  HYGIENE_CHARTER
  PHONE
  ADDRESS
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingCategory {
  COSMETIQUE
  TEXTILE
  SECONDE_MAIN
  AGRICOLE
  SERVICES
  AUTRES
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  SOLD_OUT
  ARCHIVED
}

model SellerProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  bio              String?
  heroUrl          String?
  bannerUrl        String?
  deliveryRadiusKm Int       @default(15)
  // Weekly availability as { mon: '9-18' | null, tue: ..., ... }. Free-form
  // for v1; we'll structure once sellers actually use it.
  availability     Json?
  // Spoken languages — ISO 639-1 codes (e.g. ["fr", "ln", "sw"]).
  languages        String[]  @default([])
  // PostGIS — separate from listing.location (sellers can have a HQ point
  // independent of any specific listing). Read/written via raw SQL.
  pickupPoint      Unsupported("geography(Point, 4326)")?
  promoText        String?
  promoActive      Boolean   @default(false)
  promoExpiresAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifications Verification[]
  stats         SellerStats?
  carts         Cart[]
  orders        Order[]
  listings      Listing[]

  @@map("seller_profiles")
}

model Verification {
  id          String             @id @default(cuid())
  sellerId    String
  kind        VerificationKind
  status      VerificationStatus @default(PENDING)
  // Path in the `verifications` bucket — admin reviews evidence then flips
  // status. Null until the seller uploads.
  evidenceUrl String?
  verifiedAt  DateTime?
  // User id of the admin who approved/rejected. Null while pending.
  verifiedBy  String?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  seller SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, kind])
  @@index([status, kind])
  @@map("verifications")
}

/// Materialized aggregates derived from reviews. Recomputed by the
/// `aggregates` job (wired in M8). Ships with default zeros so seller
/// profile reads have a row to return before reviews exist.
model SellerStats {
  sellerId         String   @id
  avgRating        Float    @default(0)
  ratingCount      Int      @default(0)
  // Map of rating -> count, e.g. { "5": 12, "4": 8, ... }.
  distribution     Json     @default("{}")
  // 0..1 normalized bars derived from sentiment tags / review categories.
  hygieneBar       Float    @default(0)
  qualityBar       Float    @default(0)
  packagingBar     Float    @default(0)
  topSentimentTags String[] @default([])
  updatedAt        DateTime @updatedAt

  seller SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("seller_stats")
}

model Listing {
  id          String          @id @default(cuid())
  sellerId    String
  title       String
  description String
  category    ListingCategory
  priceCents  Int
  currency    String          @default("CDF")
  location    Unsupported("geography(Point, 4326)")
  // JSON array of { id, url, sm?, md?, lg?, alt?, uploadedAt }. Variants are
  // filled in by the image-processing worker.
  photos      Json            @default("[]")
  // Free-form { variants?, sizes?, ... } — pilot shape, not validated yet.
  options     Json?
  quantityAvailable Int       @default(1)
  status      ListingStatus   @default(DRAFT)
  expiresAt   DateTime?
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  seller SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  // Generated tsvector column for full-text search. Written by Postgres on
  // every insert/update of title/description — never set from app code.
  searchVector Unsupported("tsvector")?

  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([sellerId])
  @@index([category, status])
  @@index([status, publishedAt])
  @@map("listings")
}

// ---------------------------------------------------------------------------
// M6 — Delivery
// ---------------------------------------------------------------------------

enum VehicleType {
  MOTO
  VOITURE
  VELO
  A_PIED
}

/// A delivery partner. Created by admin (POST /v1/admin/deliverers) — pilot
/// flow is curated, not self-service. The userId FK links to the existing
/// User record (whose role is also set to DELIVERY_PARTNER).
model Deliverer {
  id              String      @id @default(cuid())
  userId          String      @unique
  vehicleType     VehicleType
  // Last 3 digits visible by default; full number lives on users.phone but
  // the buyer-facing order response only ever exposes this masked form.
  phoneMasked     String
  // Updated by the deliverer's mobile app via /v1/deliveries/me/location.
  currentLocation Unsupported("geography(Point, 4326)")?
  available       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deliverers")
}

// ---------------------------------------------------------------------------
// M4 — Cart, orders
// ---------------------------------------------------------------------------

enum OrderStatus {
  PREPARING  // "Préparée"
  ON_THE_WAY // "En route"
  DELIVERED  // "Livrée"
  CANCELLED
  REFUNDED
}

enum FulfillmentType {
  DELIVERY
  PICKUP
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  // Locked the moment the first item is added; nulled when last item is
  // removed or replace is called with a different seller.
  sellerId  String?
  // Snapshotted from the first item's listing.currency. Subsequent items must
  // match (different currencies cannot coexist in one cart).
  currency  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  seller SellerProfile? @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  items  CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  listingId String
  quantity  Int
  options   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([cartId, listingId])
  @@index([cartId])
  @@map("cart_items")
}

model Order {
  id               String          @id @default(cuid())
  buyerId          String
  sellerId         String
  status           OrderStatus     @default(PREPARING)
  fulfillmentType  FulfillmentType
  // Address snapshot — copied at order creation so order survives address
  // deletion. Null for PICKUP orders.
  addressSnapshot  Json?
  subtotalCents    Int
  discountCents    Int             @default(0)
  deliveryFeeCents Int             @default(0)
  totalCents       Int
  currency         String          @default("CDF")
  etaAt            DateTime?
  delivererId      String?
  paymentId        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  buyer   User          @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller  SellerProfile @relation(fields: [sellerId], references: [id])
  items   OrderItem[]
  payment Payment?

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([sellerId, status])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                 String  @id @default(cuid())
  orderId            String
  listingId          String
  // Snapshots: order survives listing edits.
  titleSnapshot      String
  priceCentsSnapshot Int
  photoUrlSnapshot   String?
  quantity           Int
  options            Json?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// M5 — Payments
// ---------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProviderKind {
  STRIPE
  PAYPAL
  PAWAPAY
  MANUAL
}

/// One Payment per Order (1:1). Created when the buyer initiates checkout
/// via `POST /v1/orders/:id/payment`. The provider drives the lifecycle
/// through webhook callbacks; we mirror their state.
model Payment {
  id            String              @id @default(cuid())
  orderId       String              @unique
  provider      PaymentProviderKind
  // Provider-side identifier (e.g. Stripe PaymentIntent id, PayPal order id,
  // Pawapay deposit id). Null until the provider's create-intent call returns.
  providerRef   String?
  amountCents   Int
  currency      String
  status        PaymentStatus       @default(PENDING)
  capturedAt    DateTime?
  failureReason String?
  // Provider-specific payload returned to the client (clientSecret, approveUrl,
  // depositId, etc.). Never log this in clear — secrets land here for Stripe.
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  order    Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attempts PaymentAttempt[]

  @@index([status, createdAt])
  @@index([provider, providerRef])
  @@map("payments")
}

/// Audit trail of every provider interaction (intent create, confirm,
/// webhook, refund). Used for reconciliation and debugging in admin tools.
model PaymentAttempt {
  id             String              @id @default(cuid())
  paymentId      String
  // Kind of call: 'createIntent' | 'confirm' | 'webhook' | 'refund' | 'capture'.
  kind           String
  idempotencyKey String?
  provider       PaymentProviderKind
  // Redacted request payload (sensitive fields stripped).
  request        Json?
  // Sanitized provider response (id, status, error code).
  response       Json?
  status         PaymentStatus
  createdAt      DateTime            @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("payment_attempts")
}

/// Every admin action and other sensitive event is appended here.
/// Written by the AuditInterceptor when `@Audited()` decorates a handler.
model AuditLog {
  id            String   @id @default(cuid())
  actorId       String?  // null for system / unauthenticated events
  action        String   // free-form, e.g. "seller.verification.update"
  resourceType  String?  // e.g. "Seller", "Order"
  resourceId    String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  correlationId String?
  createdAt     DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([resourceType, resourceId])
  @@index([action, createdAt])
  @@map("audit_logs")
}
